@article{bucknerDeterminingStrengthCase2017,
  title = {Determining {{Strength}}: {{A Case}} for {{Multiple Methods}} of {{Measurement}}},
  author = {Buckner, Samuel L. and Jessee, Matthew B. and Mattocks, Kevin T. and Mouser, J. Grant and Counts, Brittany R. and Dankel, Scott J. and Loenneke, Jeremy P.},
  year = 2017,
  month = feb,
  journal = {Sports medicine (Auckland, N.Z.)},
  volume = {47},
  number = {2},
  pages = {193--195},
  publisher = {Sports Med},
  issn = {1179-2035},
  doi = {10.1007/S40279-016-0580-3},
  urldate = {2022-11-16},
  abstract = {Muscle strength is often measured through the performance of a one-repetition maximum (1RM). However, we that feel a true measurement of `strength' remains elusive. For example, low-load alternatives to traditional resistance training result in muscle hypertrophic changes similar to those resulting from traditional high-load resistance training, with less robust changes observed with maximal strength measured by the 1RM. However, when strength is measured using a test to which both groups are `naive', differences in strength become less apparent. We suggest that the 1RM is a specific skill, which will improve most when training incorporates its practice or when a lift is completed at a near-maximal load. Thus, if we~only recognize increases in the 1RM as indicative of strength, we will overlook many effective and diverse alternatives to traditional high-load resistance training. We wish to suggest that multiple measurements of strength assessment be utilized in order to capture a more complete picture of the adaptation to resistance training.},
  pmid = {27380100},
  keywords = {Acclimatization,Adaptation,doi:10.1007/s40279-016-0580-3,Humans,Jeremy P Loenneke,Matthew B Jessee,MEDLINE,Muscle,Muscle Strength*,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,NCBI,NIH,NLM,Physiological,pmid:27380100,PubMed Abstract,Resistance Training*,Samuel L Buckner,Skeletal / physiology*}
}

@article{bucknerProblemMuscleHypertrophy2016,
  title = {The Problem {{Of}} Muscle Hypertrophy: {{Revisited}}},
  author = {Buckner, Samuel L. and Dankel, Scott J. and Mattocks, Kevin T. and Jessee, Matthew B. and Mouser, J. Grant and Counts, Brittany R. and Loenneke, Jeremy P.},
  year = 2016,
  month = dec,
  journal = {Muscle \& Nerve},
  volume = {54},
  number = {6},
  pages = {1012--1014},
  publisher = {John Wiley \& Sons, Ltd},
  issn = {1097-4598},
  doi = {10.1002/MUS.25420},
  urldate = {2022-05-02},
  abstract = {In this paper we revisit a topic originally discussed in 1955, namely the lack of direct evidence that muscle hypertrophy from exercise plays an important role in increasing strength. To this day, long-term adaptations in strength are thought to be primarily contingent on changes in muscle size. Given this assumption, there has been considerable attention placed on programs designed to allow for maximization of both muscle size and strength. However, the conclusion that a change in muscle size affects a change in strength is surprisingly based on little evidence. We suggest that these changes may be completely separate phenomena based on: (1) the weak correlation between the change in muscle size and the change in muscle strength after training; (2) the loss of muscle mass with detraining, yet a maintenance of muscle strength; and (3) the similar muscle growth between low-load and high-load resistance training, yet divergent results in strength. Muscle Nerve 54: 1012--1014, 2016.},
  pmid = {27717161},
  keywords = {adaptation,dissociation,muscle growth,resistance training,strength}
}

@article{bucknerWhatDoesIndividual2017,
  title = {What Does Individual Strength Say about Resistance Training Status?},
  author = {Buckner, Samuel L. and Mouser, J. Grant and Jessee, Matthew B. and Dankel, Scott J. and Mattocks, Kevin T. and Loenneke, Jeremy P.},
  year = 2017,
  month = apr,
  journal = {Muscle \& nerve},
  volume = {55},
  number = {4},
  pages = {455--457},
  publisher = {Muscle Nerve},
  issn = {1097-4598},
  doi = {10.1002/MUS.25461},
  urldate = {2022-04-23},
  abstract = {The point at which an individual becomes resistance ``trained'' is not well defined in the literature. Some studies have defined training status as having engaged in consistent resistance training activities for a given period of time, whereas others base inclusion criteria on strength levels alone, or levels of strength in combination with training age/time. If the primary focus of a study is to examine adaptations in individuals with high levels of strength, then it may be appropriate to exclude the individuals who do not meet strength requirements. However, given the heterogeneity of the strength response to resistance training, strength cannot separate those who are ``trained'' from those who are ``untrained.'' We suggest that, when determining resistance training status, training age (time) and the modality of training (specificity) should be the primary criteria considered. Muscle Nerve 55: 455--457, 2017.},
  pmid = {28066901},
  keywords = {Adaptation,doi:10.1002/mus.25461,Humans,J Grant Mouser,Jeremy P Loenneke,MEDLINE,Muscle,Muscle Strength / physiology*,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,NCBI,NIH,NLM,Physiological*,pmid:28066901,PubMed Abstract,Resistance Training*,Samuel L Buckner,Skeletal / physiology*}
}

@article{buenoEmotionalMotivationalMechanisms2008,
  title = {Emotional and Motivational Mechanisms Mediating the Influence of Goal Setting on Endurance Athletes' Performance},
  author = {Bueno, Javier and Weinberg, Robert S. and {Fern{\'a}ndez-Castro}, Jordi and Capdevila, Llu{\'i}s},
  year = 2008,
  month = nov,
  journal = {Psychology of Sport and Exercise},
  volume = {9},
  number = {6},
  pages = {786--799},
  issn = {1469-0292},
  doi = {10.1016/j.psychsport.2007.11.003},
  urldate = {2023-03-28},
  abstract = {Objectives To examine several psychological mechanisms mediating the efficacy of goal setting in endurance sports. Design The athletes were randomly assigned to four experimental conditions in a 2\texttimes 2\texttimes 3 mixed design. Methods Participants were 35 male endurance athletes ranging in age from 15 to 34 years who competed at different athletic clubs of the Catalonian Track and Field Federation. They were assigned to a goal (attainable or unattainable) and pattern of social comparison (win or lose) conditions, which were the between subject variables, and phase of assessment (three repetitions) served as the repeated-measure variable. Results To analyze the role of mediator mechanisms, a structural equation modeling analysis was conducted. The results indicated that both motivational and emotional mechanisms were important mediators in improving the efficacy of goal setting in endurance sports. In particular the addition of the concept of suffering (including perceptions of threat and feelings of helplessness) was shown to be related to performance outcomes. Conclusions When setting goals, the possibility of not reaching those goals can be threatening to individuals and lead to feelings of helplessness, especially if goals are perceived as too difficult. Having strong self-efficacy to meet the goals set is important to maintain motivation.},
  langid = {english},
  keywords = {Emotion,Goal setting,Mediating mechanisms,Motivation,Self-efficacy}
}

