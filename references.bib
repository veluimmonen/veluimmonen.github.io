@article{choiCalciumactivatedForceHuman2010,
  title = {Calcium-Activated Force of Human Muscle Fibers Following a Standardized Eccentric Contraction},
  author = {Choi, Seung Jun and Widrick, Jeffrey J.},
  year = 2010,
  month = dec,
  journal = {American journal of physiology. Cell physiology},
  volume = {299},
  number = {6},
  publisher = {Am J Physiol Cell Physiol},
  issn = {1522-1563},
  doi = {10.1152/AJPCELL.00226.2010},
  urldate = {2022-05-02},
  abstract = {Peak Ca2+-activated specific force (force/fiber cross-sectional area) of human chemically skinned vastus lateralis muscle fiber segments was determined before and after a fixed-end contraction or an eccentric contraction of standardized magnitude (+0.25 optimal fiber length) and velocity (0.50 unloaded shortening velocity). Fiber myosin heavy chain (MHC) isoform content was assayed by SDS-PAGE. Posteccentric force deficit, a marker of damage, was similar for type I and IIa fibers but threefold greater for type IIa/IIx hybrid fibers. A fixed-end contraction had no significant effect on force. Multiple linear regression revealed that posteccentric force was explained by a model consisting of a fiber type-independent and a fiber type-specific component (r2 = 0.91). Preeccentric specific force was directly associated with a greater posteccentric force deficit. When preeccentric force was held constant, type I and IIa fibers showed identical susceptibility to damage, while type IIa/IIx fibers showed a significantly greater force loss. This heightened sensitivity to damage was directly related to the amount of type IIx MHC in the hybrid fiber. Our model reveals a fiber-type sensitivity of the myofilament lattice or cytoskeleton to mechanical strain that can be described as follows: type IIa/IIx {$>$} type IIa = type I. If these properties extend to fibers in vivo, then alterations in the number of type IIa/IIx fibers may modify a muscle's susceptibility to eccentric damage. Copyright \copyright{} 2010 the American Physiological Society.},
  pmid = {20810908},
  keywords = {Adult,Calcium / physiology*,doi:10.1152/ajpcell.00226.2010,Fast-Twitch / chemistry,Fast-Twitch / physiology*,Female,Humans,Jeffrey J Widrick,Male,MEDLINE,Muscle Contraction / physiology*,Muscle Fibers,Myosin Heavy Chains / analysis,Myosin Heavy Chains / physiology,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,NCBI,NIH,NLM,Non-U.S. Gov't,pmid:20810908,PubMed Abstract,Quadriceps Muscle / chemistry,Quadriceps Muscle / physiology,Research Support,Seung Jun Choi,Slow-Twitch / chemistry,Slow-Twitch / physiology*,Young Adult},
  file = {/Users/veluimmonen/Zotero/storage/LLCWZJWS/full-text.pdf}
}

@article{cholewaEffectsDietarySports2019,
  title = {Effects of Dietary Sports Supplements on Metabolite Accumulation, Vasodilation and Cellular Swelling in Relation to Muscle Hypertrophy: {{A}} Focus on "Secondary" Physiological Determinants},
  author = {Cholewa, Jason and Trexler, Eric and {Lima-Soares}, Fernanda and {de Ara{\'u}jo Pess{\^o}a}, Kassiana and {Sousa-Silva}, Rayssa and Santos, Azenildo Moura and Zhi, Xia and Nicastro, Humberto and Cabido, Christian Emmanuel Torres and {de Freitas}, Marcelo Conrado and Rossi, Fabricio and Zanchi, Nelo Eidy},
  year = 2019,
  month = apr,
  journal = {Nutrition (Burbank, Los Angeles County, Calif.)},
  volume = {60},
  pages = {241--251},
  publisher = {Nutrition},
  issn = {1873-1244},
  doi = {10.1016/J.NUT.2018.10.011},
  urldate = {2022-09-01},
  abstract = {Increased blood flow via vasodilation, metabolite production, and venous pooling contribute to the hyperemia and cellular swelling experienced during resistance training. It has been suggested that these effects play a role in hypertrophic adaptations. Over the past 2 decades, sport supplement products have been marketed to promote exercise hyperemia and intracellular fluid storage, thereby enhancing hypertrophy via acute swelling of myocytes. The three main classes of supplements hypothesized to promote exercise-induced hyperemia include vasodilators, such as nitric oxide precursor supplements; anaerobic energy system ergogenic aids that increase metabolite production, such as {$\beta$}-alanine and creatine; and organic osmolytes, such as creatine and betaine. Previous studies indicated that these dietary supplements are able to improve muscle performance and thus enhance muscle hypertrophy; however, recent evidences also point to these three classes of supplements affecting ``secondary'' physiological determinants of muscle mass accretion such as vasodilation, metabolite accumulation, and muscle cellular swelling. Although we recognize that the literature is relatively scarce regarding these topics, a better comprehension and discussion of these determinants can lead to increased knowledge and might guide further research regarding the proposed mechanisms of action of the identified compounds. In this case, increased knowledge may contribute to the development of improved efficacy, new products, or direct new research to specifically investigate those secondary effects. The aim of this review was to bring into focus new perspectives associated with secondary physiological effects induced by supplementation and to determine their relevance.},
  pmid = {30682546},
  keywords = {Adaptation,Dietary Supplements*,doi:10.1016/j.nut.2018.10.011,Eric Trexler,Exercise / physiology*,Humans,Hypertrophy,Jason Cholewa,MEDLINE,Muscle,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,NCBI,Nelo Eidy Zanchi,NIH,NLM,Performance-Enhancing Substances / pharmacology*,Physiological / drug effects*,pmid:30682546,PubMed Abstract,Resistance Training,Review,Skeletal / drug effects*,Vasodilation / drug effects*}
}

@article{cholewinskiEffectsPeakingProtocol2022,
  title = {The {{Effects}} of a {{Peaking Protocol}} on {{Heart Rate Variability}} and Its {{Predictive Associations}} with {{Wilks Coefficient}} in {{Competitive Powerlifters}}},
  author = {Cholewinski, Mitchell C and Machek, Steven B and Cardaci, Thomas D and Wilburn, Dylan T and Willoughby, Darryn S and Funderburk, Leslee K and Gallucci, Andrew R and Cholewinski, M C and Cardaci, S B and Wilburn, T D and Willoughby, D T and Funderburk, D S and Gallucci, L K},
