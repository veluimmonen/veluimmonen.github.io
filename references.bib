@article{
  title = {Philippe de {{La Hire}}, Physicien : Philosophie M\'ecanique, M\'ecanique Rationnelle, M\'ecanique Appliqu\'ee},
  shorttitle = {Philippe de {{La Hire}}, Physicien},
  author = {Schmit, Christophe},
  year = 2020,
  journal = {Archives internationales d'histoire des sciences},
  volume = {69},
  number = {182-183},
  pages = {272--351},
  publisher = {Acad\'emie internationale d'histoire des sciences},
  doi = {10.1484/J.ARIHS.5.122117},
  urldate = {2025-01-14},
  abstract = {This article gives characteristics of Philippe de La Hire's mechanics. By "mechanics" we mean both mechanical philosophy and rational and applied mechanics, and for each we analyze La Hire's principles and methods. We show that his physics is in line with mechanical philosophy, especially that of Descartes, and he also seems to follow Gassendi and mechanistic chemists from the turn of the 17th and 18th centuries. Putting La Hire's rational mechanics in perspective with that of some members of the French Academy of science, we shows that he favours the "Ancients" over the "Moderns" according to his own terminology. Generally speaking, La Hire favours geometry and "synthesis" rather than analytical developments. In statics, the Archimedean axiomatic remains a model, and we also show that he seeks to perfect machines by applying statics and geometry to them but he doesn't propose tools quantifying their functioning and improvements, unlike some scholars of the time. Moreover, La Hire's kinematics and dynamics depend on the geometry of the problem studied and on the possibility of geometrically interpreting Galilean propositions. The concepts of dynamics and the procedures of infinitesimal geometry in La Hire's work echoed practices prior to the development of analytical mechanics.},
  keywords = {applied mechanics,Calculus,Dynamics,Geometry,Mechanical philosophy,Methods,Philippe de La Hire,physicist: mechanical philosophy,Principles,rational mechanics,Statics},
  file = {/Users/veluimmonen/Zotero/storage/UIFX5LDR/Schmit - 2020 - Philippe de La Hire, physicien  philosophie mécan.pdf}
}

@article{
  title = {Origines, Histoire, \'Evolutions de La Mesure de La Force de Pr\'ehension et Des Dynamom\`etres M\'edicaux},
  author = {Petitdant, Bernard},
  year = 2017,
  month = jan,
  journal = {Kin\'esith\'erapie, la Revue},
  volume = {17},
  number = {181},
  pages = {40--58},
  issn = {1779-0123},
  doi = {10.1016/j.kine.2016.08.009},
  urldate = {2025-01-14},
  abstract = {R\'esum\'e Introduction La force de pr\'ehension est une composante du bilan de la main et du membre sup\'erieur. Le physio/kin\'esith\'erapeute s'y int\'eresse pour mesurer les d\'eficiences musculaires du membre sup\'erieur qui retentissent, in\'evitablement sur elle. La mesure de la force musculaire est r\'ealis\'ee \`a l'aide du dynamom\`etre. Nous avons recherch\'e les origines de la mesure de la force et de cet appareil et ses \'evolutions au fil du temps. Mat\'eriels et m\'ethode Nous avons recens\'e les catalogues m\'edicaux et chirurgicaux dans les bases de donn\'ees ayant num\'eris\'e des documents anciens. Nous avons \'egalement questionn\'e les bases de donn\'ees Kin\'edoc, Medline, Science direct, Google scholar, Espacenet. La plupart des dynamom\`etres trouv\'es dans ces catalogues portent le nom de leur inventeur. Sur Google et Google scholar nous avons recherch\'e des informations compl\'ementaires sur ces inventeurs. Nous n'avons mis aucune limite chronologique dans nos recherches. R\'esultats Nous avons recens\'e 74~catalogues. Nous avons \'elimin\'e 11~catalogues sp\'ecialis\'es. Pour certains fabricants nous disposions de plusieurs catalogues mais jamais de la m\^eme ann\'ee. Les plus anciens datent de 1849~le plus r\'ecent de 2003. Nous avons retenu 27~catalogues et 72~livres ou articles. Description La premi\`ere machine pour mesurer la force appara\^it en Angleterre au d\'ebut du XVIIIe~si\`ecle. C'est R\'egnier, \`a la fin du XVIIIe~si\`ecle, qui inventa le premier dynamom\`etre moderne. Nous distinguons les dynamom\`etres m\'ecaniques utilisant un ressort m\'etallique, les dynamom\`etres pneumatiques qui mettent de l'air en compression, les dynamom\`etres hydrauliques, les dynamom\`etres \`a jauges de contraintes et les dynamom\`etres \'electroniques. Au cours du XIXe~si\`ecle, les neurologues d'abord puis les anthropologues et tr\`es vite les adeptes de la culture physique s'int\'eress\`erent \`a ces appareils. Au cours du XXe~si\`ecle, les dynamom\`etres ont continu\'e \`a \'evoluer, sans que les principes de base n'en soient boulevers\'es. Conclusion Certains appareils avec ressort sont toujours utilis\'es de nos jours. L'hydraulique et l'\'electronique ont apport\'e leurs avantages sans modifier profond\'ement les principes de l'appareil. Niveau de preuve Non adapt\'e. Summary Introduction Grip strength is a component of hand and upper-limb work-up. For physiotherapists, it assesses upper limb muscle deficits, by which it is inevitably impaired. Muscle strength is measured by dynamometer. We investigated the origins of force measurement and dynamometers and their developments over time. Materials and method Medical and surgical catalogues in databases in which older documents have been digitized were examined, as were the Kinedoc, Medline, ScienceDirect, Google Scholar and Espacenet databases. Most of the dynamometers found in these catalogues are named after their inventor. Further information about the inventors was retrieved from the Google and Google Scholar databases. No time limit was applied to our research. Results Seventy-four catalogues were identified of which 11~were eliminated as being unsuitably specialized for our purposes. For certain manufacturers several catalogues were available but never for the same year. The oldest were printed in 1849~and the most recent in 2003. Twenty-seven catalogues and 72~books or articles were analysed. Description The first machine to measure strength appeared in England in the early 18th century. R\'egnier, at the end of the 18th century, invented the first modern dynamometer. We can distinguish mechanical dynamometers using a metal spring, pneumatic dynamometers using compressed air, hydraulic dynamometers, dynamometers with strain gauges, and electronic dynamometers. During the 19th century, first neurologists anthropologists and soon work-out enthusiasts took an interest in these devices. In the 20th century, hydraulics and electronics led to new developments, without changing the basic principles of dynamometry. Conclusion Some spring-based devices are still used today. Hydraulics and electronics have provided certain advantages, without profoundly changing the fundamental principles. Level of evidence Not adapted.},
  keywords = {Dynamometer,Dynamometre,Force de prehension,Grip strength,Hand,Histoire de la kinesitherapie,Histoire de la medecine,History of medicine,History of physiotherapy,Main},
  file = {/Users/veluimmonen/Zotero/storage/CEW7J6HL/S1779012316303175.html}
}

