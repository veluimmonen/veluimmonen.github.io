@article{
  title = {Muscle Volume Is a Major Determinant of Joint Torque in Humans},
  author = {Fukunaga, T. and Miyatani, M. and Tachi, M. and Kouzaki, M. and Kawakami, Y. and Kanehisa, H.},
  year = 2001,
  month = aug,
  journal = {Acta Physiologica Scandinavica},
  volume = {172},
  number = {4},
  pages = {249--255},
  issn = {0001-6772, 1365-201X},
  doi = {10.1046/j.1365-201x.2001.00867.x},
  urldate = {2025-03-26},
  abstract = {Muscle force (MF) is linearly related to physiological cross-sectional area (CSA), which is obtained from muscle volume (MV) divided by fibre length. Taking into account the fact that joint torque (TQ) is determined by MF multiplied by the moment arm, the maximal TQ would be a function of MV. This proposition was tested in the present study by investigating the relationship between MV and TQ for elbow flexor (EF) and extensor (EE) muscles of 26 males. The MVs of EF and EE were determined from a series of muscle CSA by magnetic resonance imaging (MRI), and pennation angle (h) and FL by ultrasonography (US). Maximal isometric TQ was measured at right angle of elbow joint for EF and EE. There was a highly signi\textregistered cant correlation between MV and TQ both for EF and EE (r  0.95 and 0.96 respectively) compared with that between muscle CSA and TQ, suggesting the dependence of TQ on MV. Furthermore, prediction equations for MV (MVULT) from muscle thickness (MT) measured by US was developed with reference to MVMRI by the MRI on 26 subjects, and the equations were applied to estimate MV of healthy university students (CON; 160 males) and sports athletes (ATH; 99 males). There were signi\textregistered cant linear relationships between MVULT and TQ both for EF (r  0.783) and EE (r  0.695) for all subjects (n  259). The MVULT was signi\textregistered cantly higher in ATH (by 32\% for EF and 33\% for EE, respectively) than in CON. Similarly, signi\textregistered cantly greater TQ was observed in ATH (by 35\% for EF, 37\% for EE, respectively). The h for EE showed no difference between both groups (17.8{$^\circ$} for CON and 17.5{$^\circ$} for ATH). On the other hand, the TQ to MV ratio were identical for CON and ATH. The results reveal that the muscle volume of the upper arm is a major determinant of joint torque (TQ), regardless of athletic training.},
  copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
  langid = {english},
  file = {/Users/veluimmonen/Zotero/storage/P4T9ZTH6/Fukunaga et al. - 2001 - Muscle volume is a major determinant of joint torq.pdf}
}

@article{
  title = {Anatomical Predictors of Maximum Isometric and Concentric Knee Extensor Moment},
  author = {Blazevich, Anthony J. and Coleman, David R. and Horne, Sara and Cannavan, Dale},
  year = 2009,
  month = apr,
  journal = {European Journal of Applied Physiology},
  volume = {105},
  number = {6},
  pages = {869--878},
  issn = {1439-6319, 1439-6327},
  doi = {10.1007/s00421-008-0972-7},
  urldate = {2025-03-26},
  abstract = {The most important anatomical determinants of in vivo joint moment magnitude have yet to be defined. Relationships between maximal knee extensor moment and quadriceps muscle volume, anatomical (ACSA) and physiological (PCSA) cross-sectional area, muscle architecture and moment arm (MA) were compared. Nineteen untrained men and women performed maximal isokinetic knee extensions under isometric conditions (90{$^\circ$} joint angle) and at 30{$^\circ$} and 300{$^\circ$} s-1. Magnetic resonance and ultrasound imaging techniques were used to measure vastus lateralis PCSA and fascicle length (FL), quadriceps ACSA, volume and patellar tendon MA. Muscle volume was the best predictor of extensor moment measured isometrically (R2 = 0.60) and at 30{$^\circ$} s-1 (R2 = 0.74). PCSA 9 FL was the best predictor of moment at 300{$^\circ$} s-1 (R2 = 0.59). MA was not an important predictor. ACSA was the second best predictor at all three speeds and could be recommended as an ideal measure given its relative ease of measurement.},
  copyright = {http://www.springer.com/tdm},
  langid = {english},
  file = {/Users/veluimmonen/Zotero/storage/LLTFYX2V/Blazevich et al. - 2009 - Anatomical predictors of maximum isometric and con.pdf}
}

