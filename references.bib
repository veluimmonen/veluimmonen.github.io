@article{
  title = {Maximum {{Strength-Power-Performance Relationships}} in {{Collegiate Throwers}}},
  author = {Stone, Michael H. and Sanborn, Kim and O'bryant, Harold S. and Hartman, Michael and Stone, Margaret E. and Proulx, Chris and Ward, Barrymore and Hruby, Joe},
  year = 2003,
