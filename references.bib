  urldate = {2022-04-14},
  abstract = {Analogous to checklists of recommendations such as the CONSORT statement (for randomized trials), or the QUORUM statement (for systematic reviews), which are designed to ensure the quality of reports in the medical literature, a checklist of recommendations for authors is being presented by the Journal of Medical Internet Research (JMIR) in an effort to ensure complete descriptions of Web-based surveys. Papers on Webbased surveys reported according to the CHERRIES statement will give readers a better understanding of the sample (self-)selection and its possible differences from a "representative" sample. It is hoped that author adherence to the checklist will increase the usefulness of such reports.},
