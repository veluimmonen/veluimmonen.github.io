@article{ryanSupportingAutonomyCompetence2018,
  title = {Supporting {{Autonomy}}, {{Competence}}, and {{Relatedness}}: {{The Coaching Process From}} a {{Self-Determination Theory Perspective}}},
  author = {Ryan, Richard M. and Deci, Edward L.},
  year = 2018,
  month = dec,
  journal = {Professional Coaching},
  publisher = {Springer Publishing Company},
  doi = {10.1891/9780826180094.0020},
  urldate = {2022-05-05},
  abstract = {Coaching has matured into a vibrant discipline, one aimed at facilitating the development and wellness of both individuals and organizations. Increasing evidence has made clear that coaching can be a strong asset in both personal development and organizational performance. This chapter discusses self-determination theory (SDT) as an approach of considerable utility to coaching. There is now a large scientific literature supporting the motivational principles of SDT---including those related to types of motivation, basic psychological needs, and goal contents. The chapter focuses on SDT's view of a facilitating environment---one that provides support for autonomy, competence, and relatedness. It highlights some of the specific ways in which SDT maintains that these three basic psychological need satisfactions can be supported within coaching encounters, and in the client's independent actions within organizations and everyday life. In addition, the chapter reviews how the contents of life goals affect well-being and ill-being, career commitment, and, ultimately, flourishing. It then discusses the role of mindfulness in promoting autonomous self-regulation, goal choices, and wellness. Finally the chapter highlights the empirically supported practice elements of SDT in areas relevant to the coaching endeavor. (PsycInfo Database Record (c) 2020 APA, all rights reserved)}
}

@article{sandelowskiSampleSizeQualitative1995,
  title = {Sample Size in Qualitative Research},
  author = {Sandelowski, M.},
  year = 1995,
  month = apr,
  journal = {Research in Nursing \& Health},
  volume = {18},
  number = {2},
  pages = {179--183},
  publisher = {John Wiley \& Sons, Ltd},
  issn = {1098-240X},
  doi = {10.1002/NUR.4770180211},
  urldate = {2022-10-12},
  abstract = {A common misconception about sampling in qualitative research is that numbers are unimportant in ensuring the adequacy of a sampling strategy. Yet, simple sizes may be too small to support claims of having achieved either informational redundancy or theoretical saturation, or too large to permit the deep, case-oriented analysis that is the raison-d'\^etre of qualitative inquiry. Determining adequate sample size in qualitative research is ultimately a matter of judgment and experience in evaluating the quality of the information collected against the uses to which it will be put, the particular research method and purposeful sampling strategy employed, and the research product intended.},
  pmid = {7899572}
}

