@incollection{GeneralizedLinearMixed2011,
  title = {Generalized {{Linear Mixed Effects Models}}},
  booktitle = {Applied {{Longitudinal Analysis}}},
  year = 2011,
  pages = {395--439},
  publisher = {John Wiley \& Sons, Ltd},
  doi = {10.1002/9781119513469.ch14},
  urldate = {2023-05-06},
  abstract = {This chapter describes how generalized linear models can be extended to longitudinal data. These models are known as generalized linear mixed effects models (GLMMs). The chapter examines first the linear mixed effects model as a generalized linear model, albeit one with both fixed and random effects, and then looks at how the ideas underlying the linear mixed effects model can be extended to generalized linear models. The introduction of random effects has important implications for the interpretation of the regression coefficients in GLMMs. Although the inclusion of random coefficients induces overdispersion marginally, the model nonetheless assumes Poisson variation conditional on these subject-specific effects and the covariates. The chapter briefly describes maximum likelihood estimation of the fixed effects and the random effects covariance parameters. It also illustrates GLMMs for analyzing longitudinal data from three case studies. The chapter ends with a discussion on fitting GLMMs using standard statistical software.},
  chapter = {14},
  isbn = {978-1-119-51346-9},
  langid = {english},
  keywords = {fixed effects,generalized linear mixed effects models,longitudinal data,overdispersion,Poisson variation,random effects,regression coefficients},
  file = {/Users/veluimmonen/Zotero/storage/8N23KBTA/9781119513469.html}
}

@article{gentilEFFECTSPERIODICCONTINUOUS2015,
  title = {{{EFFECTS OF PERIODIC AND CONTINUOUS RESISTANCE TRAINING ON MUSCLE STRENGTH IN DETRAINED WOMEN}}},
  author = {Gentil, Paulo and {Ferreira-Junior}, Jo{\~a}o B. and Soares, Saulo R. S. and Martorelli, Andr{\'e} S. and Bottaro, Martim and Cadore, Eduardo L. and Loenneke, Jeremy P.},
  year = 2015,
  month = dec,
  journal = {Perceptual and Motor Skills},
  volume = {121},
  number = {3},
  pages = {810--821},
  issn = {0031-5125},
  doi = {10.2466/29.30.PMS.121c23x3},
  abstract = {It has been reported that periodic resistance training (retraining after short-term detraining) could maintain muscle performance. However, the training volume used in previous studies differed between continuous and periodic training groups. This study compared strength gains following 20 sessions of continuous and periodic resistance training programs. 60 healthy, detrained women were randomly assigned into one of two groups: (1) continuous resistance training group or (2) retraining resistance group. The continuous resistance training group performed a non-interrupted resistance training program for 10 wk., while the retraining resistance group trained for 5 wk., detrained 2 wk., and resumed training for 5 wk. All participants performed three sets of 8-12 maximum repetitions of lower- and upper-body exercises two days per week, with at least 48 hr. between sessions. There was no significant difference on knee extensors and elbow flexors peak torque gain between the continuous resistance training group and the retraining resistance group. The results suggest that 2 wk. of detraining does not affect strength gains after a total of 10 wk. in detrained women.},
  langid = {english},
  pmid = {26595206},
  keywords = {Adult,Brazil,Female,Humans,Muscle Skeletal,Muscle Strength,Resistance Training,Young Adult}
}

