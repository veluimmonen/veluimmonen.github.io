  shorttitle = {Conventional Wisdom on Measurement},
  author = {Bollen, Kenneth and Lennox, Richard},
  year = 1991,
  journal = {Psychological Bulletin},
  volume = {110},
  number = {2},
  pages = {305--314},
  publisher = {American Psychological Association},
