@article{
  title = {Comparison {{Between Principal Components}} and {{Factor Analysis}} for {{Different Data}}},
  author = {Elsayed, Ahmed Mohamed Mohamed},
  year = 2022,
  month = dec,
  journal = {International Journal of Statistical Distributions and Applications},
  volume = {8},
