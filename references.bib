@misc{
  title = {A {{Delphi}} Study to Strengthen Research Methods Training in Undergraduate Psychology Programmes},
  author = {Thibault, Robert T. and {Bailey-Rodriguez}, Deborah and Bartlett, James E. and Blazey, Paul and Green, Robin J. and Pownall, Madeleine and Munafo, Marcus},
  year = 2023,
  month = jul,
  publisher = {PsyArXiv},
  doi = {10.31234/osf.io/gp9aj},
  urldate = {2023-08-02},
  abstract = {Psychology programmes often emphasise inferential statistical tests over a solid understanding of data and research design. This imbalance may leave graduates under-equipped to effectively interpret research and employ data to answer questions. We conducted a two-round modified-Delphi to identify the research methods skills that the UK psychology community deems essential for undergraduates to learn. Participants included 103 research methods instructors, academics, students, and non-academic psychologists. Of 78 items included in the consensus process, 34 reached consensus. We coupled these results with a qualitative analysis of 707 open-ended text responses to develop nine recommendations for organisations that accredit undergraduate psychology programmes---such as the British Psychological Society (BPS). We recommend that accreditation standards emphasise (1) data skills, (2) research design, (3) descriptive statistics, (4) critical analysis, (5) qualitative methods, and (6) both parameter estimation and significance testing; as well as (7) give precedence to foundational skills, (8) promote transferable skills, and (9) create space in curricula to enable these recommendations. Our data and findings can inform modernised accreditation standards to include clearly-defined, assessable, and widely-encouraged skills that foster a competent graduate body for the contemporary world.},
  langid = {american},
  keywords = {accreditation standards,British Psychological Society,consensus,Delphi,Educational Psychology,Meta-science,other,Psychology,psychology education,qualitative methods,Quantitative Methods,replication,research design,research methods,Social and Behavioral Sciences,statistics,undergraduate},
  file = {/Users/veluimmonen/Zotero/storage/N26QCQLN/Thibault ym. - 2023 - A Delphi study to strengthen research methods trai.pdf}
}

