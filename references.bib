@article{
  title = {Progressive Overload without Progressing Load? {{The}} Effects of Load or Repetition Progression on Muscular Adaptations},
  shorttitle = {Progressive Overload without Progressing Load?},
  author = {Plotkin, Daniel and Coleman, Max and Every, Derrick Van and Maldonado, Jaime and Oberlin, Douglas and Israetel, Michael and Feather, Jared and Alto, Andrew and Vigotsky, Andrew D. and Schoenfeld, Brad J.},
  year = 2022,
