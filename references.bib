  title = {The Effect of Multiple-Goal Strategies on Performance Outcomes in Training and Competition},
  author = {Filby, William C. D. and Maynard, Ian W. and Graydon, Jan K.},
  year = 1999,
  journal = {Journal of Applied Sport Psychology},
  volume = {11},
  pages = {230--246},
  publisher = {Taylor \& Francis},
  address = {United Kingdom},
  issn = {1533-1571},
  doi = {10.1080/10413209908404202},
  abstract = {Many sport psychologists have been fighting against the pervasive "winning is everything" mentality and have encouraged athletes to set only self-referenced performance and process goals. However, studies that have explored the practices of successful performers have found that they do in fact make effective use of outcome goals (R. S. Weinberg et al, 1993; G. Jones and S. Hanton, 1996). The aim of this study was to examine empirically L. Hardy et al's (1996) suggestion, that consultants should now be promoting the use of a multiple-goal strategy. 40 participants (mean age 21.68 yrs) were split into five groups of equal number and matched for ability on a soccer task. Four of the groups used different combinations of outcome, performance, and process goals while the other acted as a control group. Performance on the soccer task was measured over a 5-wk training period, and then in a competition. Two-factor (Group\enspace\texttimes\enspace Test) ANOVAs indicated significant differences between the groups for both training and competition performance. The superior performance of the groups using multiple-goal strategies provided evidence to support the efficacy of maintaining a balance between the use of outcome, performance, and process goals. (PsycInfo Database Record (c) 2022 APA, all rights reserved)},
  keywords = {Athletic Performance,Goal Setting,Soccer,Strategies},
  file = {/Users/veluimmonen/Zotero/storage/9I5JT9ZD/1999-11487-005.html}
}

