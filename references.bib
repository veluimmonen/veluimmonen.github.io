@article{signorileElectromyographicalComparisonSquat1994,
  title = {An {{Electromyographical Comparison}} of the {{Squat}} and {{Knee Extension Exercises}}},
  author = {Signorile, Joseph F. and Weber, Brad and Roll, Brad and Caruso, John F. and Lowensteyn, Ilka and Perry, Arlette C.},
  year = 1994,
