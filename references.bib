  keywords = {Adaptation Physiological,Athlete,Athletes,Athletic Performance,Exercise,Humans,Models Theoretical,Muscle growth,Muscle Skeletal,Muscle Strength,Physical Endurance,Rate of force development,Resistance exercise,Resistance Training,Sports,Torque,Vertical jump}
