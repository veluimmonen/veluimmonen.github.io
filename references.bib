  author = {Meijer, J. P. and Jaspers, R. T. and Rittweger, J. and Seynnes, O. R. and Kamandulis, S. and Brazaitis, M. and Skurvydas, A. and Pi{\v s}ot, R. and {\v S}imuni{\v c}, B. and Narici, M. V. and Degens, H.},
