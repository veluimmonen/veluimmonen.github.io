@article{harperDecreasedMitochondrialProton2002,
  title = {Decreased Mitochondrial Proton Leak and Reduced Expression of Uncoupling Protein 3 in Skeletal Muscle of Obese Diet-Resistant Women},
  author = {Harper, Mary-Ellen and Dent, Robert and Monemdjou, Shadi and B{\'e}zaire, V{\'e}ronic and Van Wyck, Lloyd and Wells, George and Kavaslar, Gul Nihan and Gauthier, Andre and Tesson, Fr{\'e}d{\'e}rique and McPherson, Ruth},
  year = 2002,
  month = aug,
  journal = {Diabetes},
  volume = {51},
  number = {8},
  pages = {2459--2466},
  issn = {0012-1797},
  doi = {10.2337/diabetes.51.8.2459},
  abstract = {Weight loss in response to caloric restriction is variable. Because skeletal muscle mitochondrial proton leak may account for a large proportion of resting metabolic rate, we compared proton leak in diet-resistant and diet-responsive overweight women and compared the expression and gene characteristics of uncoupling protein (UCP)2 and UCP3. Of 1,129 overweight women who completed the University of Ottawa Weight Management Clinic program, 353 met compliance criteria and were free of medical conditions that could affect weight loss. Subjects were ranked according to percent body weight loss during the first 6 weeks of a 900-kcal meal replacement protocol. The highest and lowest quintiles of weight loss were defined as diet responsive and diet resistant, respectively. After body weight had been stable for at least 10 weeks, 12 of 70 subjects from each group consented to muscle biopsy and blood sampling for determinations of proton leak, UCP mRNA expression, and genetic studies. Despite similar baseline weight and age, weight loss was 43\% greater, mitochondrial proton leak-dependent (state 4) respiration was 51\% higher (P = 0.0062), and expression of UCP3 mRNA abundance was 25\% greater (P {$<$} 0.001) in diet-responsive than in diet-resistant subjects. There were no differences in UCP2 mRNA abundance. None of the known polymorphisms in UCP3 or its 5' flanking sequence were associated with weight loss or UCP3 mRNA abundance. Thus, proton leak and the expression of UCP3 correlate with weight loss success and may be candidates for pharmacological regulation of fat oxidation in obese diet-resistant subjects.},
  langid = {english},
  pmid = {12145158},
  keywords = {Body Weight,Carrier Proteins,Diet Reducing,DNA Primers,Energy Intake,Female,Gene Expression Regulation,Genetic Testing,Humans,Hydrogen-Ion Concentration,Ion Channels,Membrane Transport Proteins,Mitochondria Muscle,Mitochondrial Proteins,Muscle Skeletal,Obesity,Oxygen Consumption,Proteins,Protons,RNA Messenger,Transcription Genetic,Treatment Failure,Uncoupling Protein 2,Uncoupling Protein 3,Weight Loss},
  file = {/Users/veluimmonen/Zotero/storage/UZA2GP7M/Harper ym. - 2002 - Decreased mitochondrial proton leak and reduced ex.pdf}
}

