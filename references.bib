  abstract = {Using untargeted metabolomics, Morville et al. provide a time-resolved map of circulating metabolites that are regulated in response to an acute bout of endurance exercise or resistance exercise in healthy male subjects. The authors deliver a comprehensive comparative overview of exercise-mode-dependent and mode-independent changes to the plasma metabolome.},
  pmid = {33378671},
