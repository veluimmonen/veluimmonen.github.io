@article{
  title = {Aligning Theory and Methodology in Mixed Methods Research: {{Before Design Theoretical Placement}}},
  shorttitle = {Aligning Theory and Methodology in Mixed Methods Research},
  author = {Alavi, Mousa and Archibald, Mandy and McMaster, Rose and Lopez, Violeta and Cleary, Michelle},
  year = 2018,
  month = sep,
  journal = {International Journal of Social Research Methodology},
