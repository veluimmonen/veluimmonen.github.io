  title = {Disassociation between the Effects of Amino Acids and Insulin on Signaling, Ubiquitin Ligases, and Protein Turnover in Human Muscle},
  author = {Greenhaff, P. L. and Karagounis, L. G. and Peirce, N. and Simpson, E. J. and Hazell, M. and Layfield, R. and Wackerhage, H. and Smith, K. and Atherton, P. and Selby, A. and Rennie, M. J.},
  year = 2008,
