@article{lazicProblemPseudoreplicationNeuroscientific2010,
  title = {The Problem of Pseudoreplication in Neuroscientific Studies: Is It Affecting Your Analysis?},
  shorttitle = {The Problem of Pseudoreplication in Neuroscientific Studies},
  author = {Lazic, Stanley E.},
  year = 2010,
  month = jan,
  journal = {BMC Neuroscience},
  volume = {11},
  number = {1},
  pages = {5},
  issn = {1471-2202},
  doi = {10.1186/1471-2202-11-5},
  urldate = {2023-04-17},
  abstract = {Pseudoreplication occurs when observations are not statistically independent, but treated as if they are. This can occur when there are multiple observations on the same subjects, when samples are nested or hierarchically organised, or when measurements are correlated in time or space. Analysis of such data without taking these dependencies into account can lead to meaningless results, and examples can easily be found in the neuroscience literature.},
  keywords = {Figure Caption,Firing Rate,Litter Effect,Multiple Observation,Nature Neuroscience},
  file = {/Users/veluimmonen/Zotero/storage/LVMB77LV/Lazic - 2010 - The problem of pseudoreplication in neuroscientifi.pdf;/Users/veluimmonen/Zotero/storage/VJ3UF3AB/1471-2202-11-5.html}
}

@article{leabeaterTightMarginsCompression2022,
  title = {Tight {{Margins}}: {{Compression Garment Use}} during {{Exercise}} and {{Recovery}}\&mdash;{{A Systematic Review}}},
  author = {Leabeater, Alana J. and James, Lachlan P. and Driller, Matthew W.},
  year = 2022,
  month = jul,
  journal = {Textiles 2022, Vol. 2, Pages 395-421},
  volume = {2},
  number = {3},
  pages = {395--421},
  publisher = {Multidisciplinary Digital Publishing Institute},
  issn = {2673-7248},
  doi = {10.3390/TEXTILES2030022},
  urldate = {2022-11-19},
  abstract = {Background: Compression garments (CGs) are a popular tool that may act on physiological, physical, neuromuscular, biomechanical, and/or perceptual domains during exercise and recovery from exercise, with varying levels of efficacy. While previous reviews have focused on the effects of CGs during running, high-intensity exercise, and exercise recovery, a comprehensive systematic review that assesses the effectiveness of garment use both during and after exercise has not been recently conducted. Methods: A systematic search of the literature from the earliest record until May 2022 was performed based on the PRISMA-P guidelines for systematic reviews, using the online databases PubMed, SPORTDiscus, and Google Scholar. Results: 160 articles with 2530 total participants were included for analysis in the systematic review, comprised of 103 \&lsquo;during exercise\&rsquo; studies, 42 \&lsquo;during recovery\&rsquo; studies, and 15 combined design studies. Conclusions: During exercise, CGs have a limited effect on global measures of endurance performance but may improve some sport-specific variables (e.g., countermovement jump height). Most muscle proteins/metabolites are unchanged with the use of CGs during exercise, though measures of blood lactate tend to be lowered. CGs for recovery appear to have a positive benefit on subsequent bouts of endurance (e.g., cycling time trials) and resistance exercise (e.g., isokinetic dynamometry). CGs are associated with reductions in lactate dehydrogenase during recovery and are consistently associated with decreases in perceived muscle soreness following fatiguing exercise. This review may provide a useful point of reference for practitioners and researchers interested in the effect of CGs on particular outcome variables or exercise types.},
  keywords = {compressive,endurance,muscle soreness,performance,recovery,sports technology,strength},
  file = {/Users/veluimmonen/Zotero/storage/FZID5C9W/full-text.pdf}
}

@article{lebonBenefitsMotorImagery2010,
  title = {Benefits of Motor Imagery Training on Muscle Strength},
  author = {Lebon, Florent and Collet, Christian and Guillot, Aymeric},
  year = 2010,
  month = jun,
  journal = {Journal of strength and conditioning research},
  volume = {24},
  number = {6},
  pages = {1680--1687},
  publisher = {J Strength Cond Res},
  issn = {1533-4287},
  doi = {10.1519/JSC.0B013E3181D8E936},
  urldate = {2022-05-06},
  abstract = {It is well established that motor imagery (MI) improves motor performance and motor learning efficiently. Previous studies provided evidence that muscle strength may benefit from MI training, mainly when movements are under the control of large cortical areas in the primary motor cortex. The purpose of this experiment is to assess whether MI might improve upper and lower limbs' strength through an ecological approach and validation, with complex and multijoint exercises. Nine participants were included in the MI group and 10 in the control (CTRL) group. The 2 groups performed identical bench press and leg press exercises. The MI group was instructed to visualize and feel the correspondent contractions during the rest period, whereas the CTRL group carried out a neutral task. The maximal voluntary contraction (MVC) and the maximal number of repetitions (MR) using 80\% of the pre-test MVC weight were measured. Although both MI and CTRL groups enhanced their strength through the training sessions, the leg press MVC was significantly higher in the MI group than in the CTRL group (p {$<$} 0.05). The interaction between the leg press MR and the group was marginally significant (p = 0.076). However, we did not find any difference between the MI and CTRL groups, both in the bench press MVC and MR. MI-related training may contribute to the improvement of lower limbs performance by enhancing the technical execution of the movement, and the individual intrinsic motivation. From an applied and practical perspective, we state that athletes may perform imagined muscles contractions, most especially during the rest periods of their physical training, to contribute to the enhancement of concentric strength. \copyright{} 2010 National Strength and Conditioning Association.},
  pmid = {20508474},
  keywords = {Adolescent,Aymeric Guillot,Christian Collet,doi:10.1519/JSC.0b013e3181d8e936,Florent Lebon,Humans,Imagery,Lower Extremity / physiology,MEDLINE,Muscle,Muscle Contraction / physiology,Muscle Strength / physiology*,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,NCBI,NIH,NLM,pmid:20508474,Psychotherapy*,PubMed Abstract,Resistance Training / methods*,Skeletal / physiology*,Upper Extremity / physiology,Young Adult}
}

@article{lemeurTaperingCompetitionReview2012,
  title = {Tapering for Competition: {{A}} Review},
  author = {Le Meur, Y. and Hausswirth, C. and Mujika, I.},
  year = 2012,
  month = apr,
  journal = {Science \& Sports},
  volume = {27},
  number = {2},
  pages = {77--87},
  publisher = {Elsevier Masson},
  issn = {0765-1597},
  doi = {10.1016/J.SCISPO.2011.06.013},
  urldate = {2022-04-13},
  abstract = {Topics: The taper is a progressive nonlinear reduction of the training load during a variable period of time, in an attempt to reduce the physiological and psychological stress of daily training and optimize sports performance. Existing research has defined the taper, identified various forms used in contemporary sport, and examined the prescription of training volume, load, intensity, duration, and type (progressive or step). The current literature reveals that tapering strategies may be associated with a competition performance improvement of about 3\% (usual range 0.5-6.0\%). Particular attention given to nutrition, hydration and recovery strategies during the pre-event taper may help maximize its associated positive effects. Interactions between the taper and long-haul travel, heat, and altitude should be also taken into account with particular attention. Conclusion: Future progress in sports science will play an important part in refining and developing existing tapering methodologies, particularly in the context of multiple peaking for team and racquet sports. \copyright{} 2011 Elsevier Masson SAS.},
  keywords = {Environment,Peaking,Performance,Recovery,Training}
}

@article{leppamakiBrightlightExposureCombined2002,
  title = {Bright-Light Exposure Combined with Physical Exercise Elevates Mood},
  author = {Lepp{\"a}m{\"a}ki, S. and Partonen, T. and L{\"o}nnqvist, J.},
  year = 2002,
  month = nov,
  journal = {Journal of Affective Disorders},
  volume = {72},
  number = {2},
  pages = {139--144},
  publisher = {Elsevier},
  issn = {0165-0327},
  doi = {10.1016/S0165-0327(01)00417-7},
  urldate = {2022-04-28},
  abstract = {Background: Physical exercise alleviates depressive symptoms, as does exposure to bright light, especially in those with seasonal variation. Our objective was to compare the effect of exercise alone or combined with morning bright light on mood and the health-related quality of life in healthy subjects. Methods: Study subjects were working-age adults, randomized in two groups (n=80): exercise in bright light (group A), or exercise in normal indoor illumination (group B). Intervention lasted for 8 weeks and questionnaire data on mood and the health-related quality of life were collected at study entry, and at weeks 4 and 8. Results: Physical exercise both in normal indoor illumination and in bright light was effective at alleviating depressive symptoms. The exercise was significantly more effective at alleviating so-called atypical depressive symptoms when combined with bright-light exposure. Limitations: There was no active placebo condition, but a comparative, randomized trial was executed. Conclusions: Physical exercise in bright light had a positive effect on mood and health-related quality of life in a sample of healthy, working-age people. Further research is needed to explore the mechanisms of the apparent additive effect of exercise and light. \copyright{} 2002 Elsevier Science B.V. All rights reserved.},
  pmid = {12200204},
  keywords = {Exercise,Light,Mood,Quality of life,Sub-syndromal seasonal depression}
}

