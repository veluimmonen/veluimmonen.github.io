@article{
  title = {Early Resistance Training-Induced Increases in Muscle Cross-Sectional Area Are Concomitant with Edema-Induced Muscle Swelling},
  author = {Damas, Felipe and Phillips, Stuart M. and Lixandr{\~a}o, Manoel E. and Vechin, Felipe C. and Libardi, Cleiton A. and Roschel, Hamilton and Tricoli, Valmor and Ugrinowitsch, Carlos},
  year = 2016,
  month = jan,
  journal = {European Journal of Applied Physiology},
  volume = {116},
  number = {1},
  pages = {49--56},
  issn = {1439-6327},
  doi = {10.1007/s00421-015-3243-4},
  abstract = {PURPOSE: It has been proposed that skeletal muscle shows signs of resistance training (RT)-induced muscle hypertrophy much earlier (i.e., \textasciitilde 3-4 weeks of RT) than previously thought. We determined if early increases in whole muscle cross-sectional area (CSA) during a period of RT were concomitant with edematous muscle swelling and thus not completely attributable to hypertrophy. METHODS: We analyzed vastus lateralis muscle ultrasound CSA images and their respective echo intensities (CSA-USecho) at the beginning (T1), in the 3rd week of RT (T2) and at the end (T3) of a 10-week RT period in ten untrained young men. Functional parameters [training volume (TV = load \texttimes{} reps \texttimes{} sets) and maximal voluntary contraction (MVC)] and muscle damage markers (myoglobin and interleukin-6) were also assessed. RESULT: Muscle CSA increased significantly at T2 (\textasciitilde 2.7\%) and T3 (\textasciitilde 10.4\%) versus T1. Similarly, CSA-USecho increased at T2 (\textasciitilde 17.2\%) and T3 (\textasciitilde 13.7\%). However, when CSA-USecho was normalized to the increase in muscle CSA, only T2 showed a significantly higher USecho versus T1. Additionally, TV increased at T2 and T3 versus T1, but MVC increased only at T3. Myoglobin and Interleukin-6 were elevated at T2 versus T1, and myoglobin was also higher at T2 versus T3. CONCLUSION: We propose that early RT-induced increases in muscle CSA in untrained young individuals are not purely hypertrophy, since there is concomitant edema-induced muscle swelling, probably due to muscle damage, which may account for a large proportion of the increase. Therefore, muscle CSA increases (particularly early in an RT program) should not be labeled as hypertrophy without some concomitant measure of muscle edema/damage.},
  langid = {english},
  pmid = {26280652},
  keywords = {Adaptation Physiological,Adult,Echo intensity,Edema,Exercise,Humans,Hypertrophy,Male,Muscle Contraction,Muscle damage,Muscle hypertrophy,Muscle Skeletal,Muscular Diseases,Quadriceps Muscle,Resistance exercise,Resistance Training,Skeletal muscle,Ultrasound,Weight Lifting}
}

