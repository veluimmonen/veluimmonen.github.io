@article{
  title = {Training {{Practices}} and {{Ergogenic Aids Used}} by {{Male Bodybuilders}}},
  author = {Hackett, Daniel A. and Johnson, Nathan A. and Chow, Chin-Moi},
  year = 2013,
  month = jun,
  journal = {The Journal of Strength \& Conditioning Research},
  volume = {27},
  number = {6},
