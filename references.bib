  author = {Franco, V{\'i}thor Rosa and Heene, Moritz and Domingue, Ben and Jim{\'e}nez, Marcos},
  year = 2023,
  month = dec,
  publisher = {OSF},
  doi = {10.31234/osf.io/cm4he},
  urldate = {2024-12-07},
  abstract = {Measurement in psychology is usually associated with psychometrics. Despite all the theoretical breakthroughs allowed by psychometric methods, they represent only a restricted range of possible measures in social sciences. Representational measurement theory (RMT) generalizes the procedures of measurement in hard sciences to applications that can be useful for social scientists. However, RMT is still unknown to many researchers, mainly because of its abstract nature as a branch of mathematics. The objective of this is paper is to present an introduction to measurement theory that focusses more on its intuitive understanding rather than on its technical aspects. This paper is structured as follows. First, we present general description of measurement theory with special focus on representational measurement theory (RMT). We then describe the main characteristics of the four main problems of RMT (i.e., representation, uniqueness, scaling, and meaningfulness). Finally, we discuss some important aspects for future research.},
  archiveprefix = {OSF},
  langid = {american},
  keywords = {Psychometrics,Representational measurement theory,Scaling},
