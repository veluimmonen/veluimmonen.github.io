  issn = {1938-1344},
  doi = {10.2519/jospt.2023.11853},
  abstract = {Responder analyses are methods for analyzing randomized controlled trials, which purport to identify individuals or subgroups of study participants who experienced a "clinically meaningful" improvement from a treatment. Unfortunately, responder analyses have numerous methodological shortcomings, which preclude inferences concerning individual response to treatments and thus adoption into clinical practice. In this viewpoint, we summarize two major limitations of responder analyses: 1) their thresholds of success involve arbitrary criteria and 2) responder analyses do not capture true individual treatment effects.},
