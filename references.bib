@misc{
  title = {Putting {{Variation}} into {{Variance}}: {{Modeling Between-Study Heterogeneity}} in {{Meta-Analysis}}},
  shorttitle = {Putting {{Variation}} into {{Variance}}},
  author = {Williams, Donald R. and Rodriguez, Josue E. and B{\"u}rkner, Paul-Christian},
  year = 2021,
